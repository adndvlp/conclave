  <title>Conclave — Stop choosing. Make them debate.</title>
  <link rel="icon" type="image/svg+xml" href="/conclave/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />

  <style>
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box }
    html { scroll-behavior:smooth }
    body {
      font-family:'Inter',-apple-system,sans-serif;
      background:#06060a;
      color:#e8e2e2;
      line-height:1.7;
      font-size:18px;
      -webkit-font-smoothing:antialiased;
      overflow-x:hidden;
    }

    ::-webkit-scrollbar { width:4px }
    ::-webkit-scrollbar-track { background:#06060a }
    ::-webkit-scrollbar-thumb { background:#8b0000; border-radius:2px }

    #particles { position:fixed; inset:0; z-index:0; pointer-events:none }

    .glow {
      position:fixed; width:600px; height:600px; border-radius:50%;
      pointer-events:none; z-index:2;
      transform:translate(-50%,-50%);
      background:radial-gradient(circle, rgba(180,20,20,0.10) 0%, transparent 70%);
      opacity:0; transition:opacity 0.3s;
      mix-blend-mode:screen;
    }

    /* ── Nav ── */
    nav {
      position:fixed; top:0; left:0; right:0; z-index:100;
      padding:1rem 2rem;
      display:flex; justify-content:space-between; align-items:center;
      background:rgba(6,6,10,0.7); backdrop-filter:blur(20px);
      border-bottom:1px solid rgba(255,255,255,0.04);
    }
    .logo {
      font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:1.5rem;
      background:linear-gradient(135deg, #dc2626, #b8860b);
      -webkit-background-clip:text; background-clip:text; color:transparent;
    }
    .nav-links { display:flex; gap:2.5rem; list-style:none }
    .nav-links a {
      color:#888; text-decoration:none; font-size:0.95rem; font-weight:500;
      transition:color 0.2s; letter-spacing:-0.01em;
    }
    .nav-links a:hover { color:#dc2626 }

    /* ── Layout ── */
    .wrapper { position:relative; z-index:5; max-width:1200px; margin:0 auto; padding:0 2rem }

    /* ── Hero ── */
    .hero {
      min-height:100vh; display:flex; flex-direction:column;
      justify-content:center; padding:6rem 0 4rem;
    }

    .hero-badge {
      display:inline-flex; align-items:center; gap:8px;
      padding:0.5rem 1.4rem; border-radius:100px;
      background:rgba(220,38,38,0.08); border:1px solid rgba(220,38,38,0.2);
      font-size:0.8rem; color:#e08080; font-weight:500;
      width:fit-content; margin-bottom:2rem;
      animation:in 0.8s ease 0.2s both;
    }

    h1 {
      font-family:'Space Grotesk',sans-serif;
      font-size:clamp(2.5rem,7vw,5.5rem); font-weight:700;
      line-height:1.04; letter-spacing:-0.03em; max-width:750px;
      margin-bottom:1.5rem;
      animation:in 0.8s ease 0.3s both;
    }
    h1 .gradient-text {
      background:linear-gradient(135deg, #dc2626 0%, #b8860b 100%);
      -webkit-background-clip:text; background-clip:text; color:transparent;
    }

    .hero-desc {
      font-size:1.3rem; color:#908890; max-width:560px;
      line-height:1.75; margin-bottom:2.5rem;
      animation:in 0.8s ease 0.4s both;
    }

    .hero-actions {
      display:flex; gap:1rem; flex-wrap:wrap; align-items:center;
      animation:in 0.8s ease 0.5s both;
    }

    .btn {
      display:inline-flex; align-items:center; gap:8px;
      padding:0.9rem 2rem; border-radius:100px;
      font-weight:600; font-size:0.95rem; text-decoration:none;
      transition:all 0.3s; cursor:pointer; border:1px solid transparent;
    }
    .btn-primary {
      background:linear-gradient(135deg, #a21212, #dc2626);
      color:#fff; box-shadow:0 8px 30px rgba(180,20,20,0.3);
    }
    .btn-primary:hover {
      transform:translateY(-2px); box-shadow:0 14px 40px rgba(220,38,38,0.4);
    }
    .btn-outline {
      background:transparent; border-color:rgba(255,255,255,0.12); color:#c0c0d0;
    }
    .btn-outline:hover { border-color:#dc2626; color:#fff }

    .install-box {
      display:inline-flex; align-items:center; gap:10px;
      background:rgba(20,20,30,0.6); border:1px solid rgba(255,255,255,0.06);
      border-radius:100px; padding:0.6rem 0.6rem 0.6rem 1.5rem;
      font-family:'JetBrains Mono',monospace; font-size:0.82rem;
      cursor:pointer; transition:all 0.3s;
    }
    .install-box:hover { border-color:rgba(220,38,38,0.3); }
    .install-box .prompt { color:#b8860b; }
    .install-box .cmd { color:#c0c0d0; }
    .install-box .copy-btn {
      background:#a21212; color:#fff; border:none; padding:0.5rem 1.2rem;
      border-radius:100px; cursor:pointer; font-family:'Inter',sans-serif;
      font-size:0.75rem; font-weight:600; transition:background 0.2s;
    }
    .install-box .copy-btn:hover { background:#c41e3a }

    /* ── Sections ── */
    section { padding:6rem 0 }

    .section-label {
      font-size:0.8rem; text-transform:uppercase; letter-spacing:5px;
      color:#dc2626; font-weight:600; margin-bottom:0.6rem;
    }

    .section-title {
      font-family:'Space Grotesk',sans-serif;
      font-size:clamp(2rem,4vw,2.8rem); font-weight:700;
      letter-spacing:-0.02em; margin-bottom:0.5rem;
    }
    .section-line {
      width:50px; height:2px;
      background:linear-gradient(90deg, #dc2626, #b8860b);
      margin-top:1rem;
    }

    /* ── Flow ── */
    .flow {
      display:flex; align-items:center; justify-content:center;
      gap:0; flex-wrap:wrap; margin:2rem 0;
    }
    .flow-step {
      background:rgba(20,20,30,0.5); backdrop-filter:blur(10px);
      border:1px solid rgba(255,255,255,0.05); border-radius:20px;
      padding:1.8rem 2.4rem; text-align:center; transition:all 0.3s;
      min-width:150px; z-index:1;
    }
    .flow-step:hover { border-color:rgba(220,38,38,0.3); transform:translateY(-4px); }
    .flow-step i { font-size:1.5rem; color:#c06060; margin-bottom:0.5rem; }
    .flow-step .label { font-weight:600; font-size:0.9rem; }
    .flow-step .sub { font-size:0.75rem; color:#686880; margin-top:0.15rem; }
    .flow-arrow { color:#b8860b; font-size:1.3rem; margin:0 -0.2rem; z-index:2; }

    /* ── TUI Mock ── */
    .tui-mock {
      background:rgba(12,14,20,0.8); backdrop-filter:blur(16px);
      border:1px solid rgba(255,255,255,0.06); border-radius:24px;
      padding:1.8rem; max-width:560px; margin:2.5rem auto 0;
      font-family:'JetBrains Mono',monospace; font-size:0.82rem;
      line-height:1.9; color:#c0c0d8;
    }
    .tui-mock .red { color:#e06060 }
    .tui-mock .gold { color:#c9973b }
    .tui-mock .dim { color:#606080 }
    .tui-mock .faint { opacity:0.3 }

    /* ── Cards ── */
    .cards {
      display:grid;
      grid-template-columns:repeat(auto-fit, minmax(300px, 1fr));
      gap:1.5rem;
    }

    .card {
      background:rgba(18,20,30,0.5); backdrop-filter:blur(14px);
      border:1px solid rgba(255,255,255,0.04); border-radius:24px;
      padding:2.2rem; transition:all 0.35s; position:relative;
      overflow:hidden;
    }
    .card::before {
      content:''; position:absolute; top:0; left:0; right:0; height:1px;
      background:linear-gradient(90deg, transparent, #dc2626, #b8860b, transparent);
      opacity:0; transition:opacity 0.35s;
    }
    .card:hover {
      transform:translateY(-6px);
      border-color:rgba(220,38,38,0.15);
      background:rgba(24,28,38,0.6);
    }
    .card:hover::before { opacity:1 }
    .card-icon {
      width:52px; height:52px; border-radius:14px;
      background:rgba(220,38,38,0.08);
      display:flex; align-items:center; justify-content:center;
      margin-bottom:1.3rem; font-size:1.3rem; color:#c06060;
      border:1px solid rgba(255,255,255,0.03);
      transition:all 0.3s;
    }
    .card:hover .card-icon { background:rgba(220,38,38,0.15); transform:scale(1.05) }
    .card h3 { font-family:'Space Grotesk',sans-serif; font-weight:600; font-size:1.25rem; margin-bottom:0.6rem; letter-spacing:-0.01em }
    .card p { color:#888; font-size:1.02rem; line-height:1.65 }

    /* ── Stats ── */
    .stats { display:grid; grid-template-columns:repeat(4, 1fr); gap:2rem; text-align:center }
    .stat-num {
      font-family:'Space Grotesk',sans-serif; font-size:3.2rem; font-weight:700;
      background:linear-gradient(135deg, #dc2626, #b8860b);
      -webkit-background-clip:text; background-clip:text; color:transparent;
      line-height:1; margin-bottom:0.4rem;
    }
    .stat-label { font-size:0.75rem; color:#686880; text-transform:uppercase; letter-spacing:2px; font-weight:500 }

    /* ── Footer ── */
    footer {
      border-top:1px solid rgba(255,255,255,0.04); padding:2.5rem 0;
      display:flex; justify-content:space-between; align-items:center;
      flex-wrap:wrap; gap:1rem; color:#606080; font-size:0.95rem;
    }
    footer a { color:#b8860b; text-decoration:none }
    footer a:hover { text-decoration:underline }

    .reveal { opacity:0; transform:translateY(30px); transition:all 0.7s ease }
    .reveal.visible { opacity:1; transform:translateY(0) }

    @keyframes in {
      from { opacity:0; transform:translateY(20px) }
      to { opacity:1; transform:translateY(0) }
    }

    @media(max-width:768px) {
      .hero { min-height:auto; padding:5rem 0 3rem }
      h1 { font-size:2.2rem }
      .flow { flex-direction:column; gap:0.5rem }
      .flow-arrow { transform:rotate(90deg); margin:0 }
      .stats { grid-template-columns:repeat(2,1fr) }
      .nav-links { display:none }
      footer { flex-direction:column; text-align:center }
      .install-box { font-size:0.65rem; padding:0.4rem 0.4rem 0.4rem 1rem }
    }
  </style>
</head>
<body>
  <canvas id="particles"></canvas>
  <div class="glow" id="glow"></div>

  <nav>
    <div class="logo"><img src="/conclave/favicon.svg" alt="" width="22" height="22" style="vertical-align:middle;margin-right:6px">Conclave</div>
    <ul class="nav-links">
      <li><a href="#how">How</a></li>
      <li><a href="#features">Features</a></li>
      <li><a href="#install">Install</a></li>
      <li><a href="https://github.com/adndvlp/conclave">GitHub</a></li>
    </ul>
  </nav>

  <div class="wrapper">
    <section class="hero">
      <div class="hero-badge">STOP CHOOSING. MAKE THEM DEBATE.</div>
      <h1>Every week a new <span class="gradient-text">"best LLM"</span>. What if you didn't have to pick?</h1>
      <p class="hero-desc">Conclave puts Claude, GPT, Gemini, and DeepSeek in the same room. They deliberate in real rounds. The best idea wins. <strong>No API key? Use your existing Claude Code or Gemini CLI.</strong></p>
      <div class="hero-actions">
        <div class="install-box" onclick="copy()">
          <span class="prompt">$</span>
          <span class="cmd">curl -fsSL https://raw.githubusercontent.com/adndvlp/conclave/main/install.sh | bash</span>
          <button class="copy-btn" id="cb">Copy</button>
        </div>
        <a href="#how" class="btn btn-outline"><i class="fas fa-arrow-down"></i> How it works</a>
        <a href="https://github.com/adndvlp/conclave" class="btn btn-primary"><i class="fab fa-github"></i> GitHub</a>
      </div>
    </section>

    <section id="how">
      <div style="text-align:center;margin-bottom:3rem" class="reveal">
        <div class="section-label">Architecture</div>
        <h2 class="section-title">How Conclave Works</h2>
        <div class="section-line" style="margin:1rem auto 0"></div>
      </div>

      <div class="flow">
        <div class="flow-step reveal"><i class="fas fa-user"></i><div class="label">You ask</div><div class="sub">"Build auth system"</div></div>
        <div class="flow-arrow"><i class="fas fa-arrow-right"></i></div>
        <div class="flow-step reveal"><i class="fas fa-users"></i><div class="label">Team debates</div><div class="sub">Multi-round deliberation</div></div>
        <div class="flow-arrow"><i class="fas fa-arrow-right"></i></div>
        <div class="flow-step reveal"><i class="fas fa-check-circle"></i><div class="label">Converges</div><div class="sub">By merit & consensus</div></div>
        <div class="flow-arrow"><i class="fas fa-arrow-right"></i></div>
        <div class="flow-step reveal"><i class="fas fa-bolt"></i><div class="label">Implements</div><div class="sub">Production code</div></div>
      </div>

      <div class="tui-mock reveal">
        <div><span class="red">Conclave 1</span> <span class="dim">(2 models)</span></div>
        <div class="faint">━━━━━━━━━━━━━━━━━━━━━━━━━━━</div>
        <div><span class="red">Team debating</span> <span class="dim">· Round 1/3</span></div>
        <div class="dim">  DeepSeek V4 Flash: <span class="gold">LEAD</span> — Auth system architecture</div>
        <div class="dim">  GLM-5.1: <span class="gold">SUPPORT:DeepSeek</span> — Backend expert</div>
        <div class="faint">━━━━━━━━━━━━━━━━━━━━━━━━━━━</div>
        <div><span class="gold">Converged</span> <span class="dim">— DeepSeek V4 Flash implements</span></div>
      </div>
    </section>

    <!-- Fork leverage explainer -->
    <section>
      <div style="max-width:700px;margin:0 auto;text-align:center" class="reveal">
        <div class="section-label">Built On</div>
        <h2 class="section-title" style="font-size:1.6rem">Standing on <span style="color:#b8860b">OpenCode's</span> shoulders</h2>
      </div>

      <div style="display:flex;align-items:center;justify-content:center;gap:2rem;flex-wrap:wrap;margin:2rem 0" class="reveal">
        <div style="background:rgba(18,20,30,0.5);border:1px solid rgba(255,255,255,0.04);border-radius:20px;padding:1.5rem 2rem;text-align:center;max-width:280px">
          <div style="font-size:1rem;color:#888;margin-bottom:0.3rem">OpenCode</div>
          <div style="font-family:'JetBrains Mono',monospace;font-size:0.75rem;color:#686880;line-height:1.6">
            /connect<br>/models<br>/agents<br>git<br>tools<br>LSP<br>providers<br>TUI
          </div>
        </div>
        <div style="font-size:2rem;color:#b8860b">+</div>
        <div style="background:rgba(18,20,30,0.5);border:1px solid rgba(220,38,38,0.2);border-radius:20px;padding:1.2rem 1.5rem;text-align:center;max-width:220px">
          <div style="font-size:1rem;color:#e06060;margin-bottom:0.3rem">Team Layer</div>
          <div style="font-family:'JetBrains Mono',monospace;font-size:0.75rem;color:#c06060;line-height:1.6">
            /team<br>debate.ts<br>prompts.ts<br>team.ts<br>processor<br>signals
          </div>
        </div>
        <div style="font-size:2rem;color:#b8860b">=</div>
        <div style="background:rgba(18,20,30,0.5);border:1px solid rgba(184,134,11,0.3);border-radius:20px;padding:1.5rem 2rem;text-align:center;max-width:200px">
          <div style="font-family:'Space Grotesk',sans-serif;font-size:1.5rem;font-weight:700;background:linear-gradient(135deg,#dc2626,#b8860b);-webkit-background-clip:text;background-clip:text;color:transparent">Conclave</div>
        </div>
      </div>

      <p class="reveal" style="text-align:center;color:#888;max-width:550px;margin:0 auto;font-size:0.95rem;line-height:1.6">
        OpenCode already had providers, agents, git, tools, and a polished TUI. <strong style="color:#b8860b">Conclave adds one thing:</strong> a team debate engine. ~12 files modified. The rest is OpenCode doing what it does best.
      </p>
    </section>

    <section id="features">
      <div style="text-align:center;margin-bottom:3rem" class="reveal">
        <div class="section-label">Capabilities</div>
        <h2 class="section-title">Why Debate <span style="color:#b8860b">Beats</span> Solo</h2>
        <div class="section-line" style="margin:1rem auto 0"></div>
      </div>

      <div class="cards">
        <div class="card reveal"><div class="card-icon"><i class="fas fa-check-double"></i></div><h3>Democratic Consensus</h3><p>No single model decides. Structured rounds with LEAD, SUPPORT, ALIGN, BUILD, CHALLENGE signals. Winner chosen by endorsement score.</p></div>
        <div class="card reveal"><div class="card-icon"><i class="fas fa-magnifying-glass"></i></div><h3>Blind Spot Detection</h3><p>One model catches what another misses. Architecture flaws, edge cases, and security issues caught during deliberation.</p></div>
        <div class="card reveal"><div class="card-icon"><i class="fas fa-chart-line"></i></div>          <h3>Live Reasoning</h3><p>Watch each model think in real-time. Click to expand reasoning blocks. Round summaries always visible.</p></div>
        <div class="card reveal"><div class="card-icon"><i class="fas fa-terminal"></i></div><h3>CLI Adapters</h3><p>Connect Claude Code, Gemini CLI, or Codex as team members. No API keys needed — uses your existing CLI auth. Perfect for those with subscriptions but no API access.</p></div>
        <div class="card reveal"><div class="card-icon"><i class="fas fa-plug"></i></div><h3>Any Provider</h3><p>OpenAI, Anthropic, DeepSeek, Google, NVIDIA, Groq, Ollama. Mix API and CLI models in the same team.</p></div>
        <div class="card reveal"><div class="card-icon"><i class="fas fa-bookmark"></i></div><h3>Persistent Teams</h3><p>Multiple named teams with different model combos. Survive restarts. Switch with a single command.</p></div>
        <div class="card reveal"><div class="card-icon"><i class="fas fa-sitemap"></i></div><h3>Breaking Teams</h3><p>LLMs autonomously split into sub-teams for complex tasks. Frontend and backend in parallel with cross-team communication.</p></div>
      </div>
    </section>

    <section>
      <div style="text-align:center;margin-bottom:2rem" class="reveal">
        <div class="section-label">The Pitch</div>
        <h2 class="section-title">One LLM guesses. A <span style="color:#b8860b">team</span> debates.</h2>
        <div class="section-line" style="margin:1rem auto 0"></div>
      </div>
      <div class="stats">
        <div class="reveal"><div class="stat-num">Any</div><div class="stat-label">Team Size</div></div>
        <div class="reveal"><div class="stat-num">∞</div><div class="stat-label">Rounds</div></div>
        <div class="reveal"><div class="stat-num">MIT</div><div class="stat-label">License</div></div>
        <div class="reveal"><div class="stat-num">All</div><div class="stat-label">Providers</div></div>
      </div>
    </section>

    <section id="install" style="text-align:center">
      <div class="reveal">
        <div class="section-label">Install</div>
        <h2 class="section-title">Start Your Conclave</h2>
        <div class="section-line" style="margin:1rem auto 2rem"></div>
        <div class="install-box" onclick="copy2()" style="margin:0 auto">
          <span class="prompt">$</span>
          <span class="cmd">curl -fsSL https://raw.githubusercontent.com/adndvlp/conclave/main/install.sh | bash</span>
          <button class="copy-btn" id="cb2">Copy</button>
        </div>
      </div>
    </section>

    <section>
      <div style="text-align:center;margin-bottom:2rem" class="reveal">
        <div class="section-label">v1 Constraints</div>
        <h2 class="section-title">What to <span style="color:#b8860b">Expect</span></h2>
        <div class="section-line" style="margin:1rem auto 0"></div>
      </div>

      <div class="cards">
        <div class="card reveal">
          <div class="card-icon"><i class="fas fa-window-maximize"></i></div>
          <h3>Context windows are real</h3>
          <p>Each model has its own context limit. Conclave auto-truncates the debate thread per model — large-context models see everything, small-context models see signal summaries. No crashes, no compaction failures. Pair a 1M-token model (DeepSeek) with a 128K model (Gemini Flash) for optimal depth vs speed.</p>
        </div>
        <div class="card reveal">
          <div class="card-icon"><i class="fas fa-clock"></i></div>
          <h3>Latency is additive</h3>
          <p>3 models debating 3 rounds = 9 API calls per message. Responses take longer than a single LLM. The tradeoff: better output quality for more complex tasks. For simple questions, switch to single model mode.</p>
        </div>
        <div class="card reveal">
          <div class="card-icon"><i class="fas fa-coins"></i></div>
          <h3>Cost mirrors team size</h3>
          <p>Each team member makes independent API calls. A 3-model team costs 3× more per message. Free tiers (Gemini CLI, Ollama local models) offset this. Choose your team based on task complexity, not just model quality.</p>
        </div>
        <div class="card reveal">
          <div class="card-icon"><i class="fas fa-flask"></i></div>
          <h3>This is v1</h3>
          <p>Conclave is weeks old. The debate engine works, teams persist, providers connect. But expect rough edges. Context optimization, live streaming, and Breaking Teams are on the roadmap. Feedback and contributions welcome.</p>
        </div>
      </div>
    </section>

    <footer>
      <div>Conclave · Fork of <a href="https://github.com/anomalyco/opencode">OpenCode</a> · <a href="https://github.com/adndvlp/conclave/blob/main/LICENSE">MIT</a></div>
      <div><a href="https://github.com/adndvlp/conclave"><i class="fab fa-github"></i> adndvlp/conclave</a></div>
    </footer>
  </div>

  <script is:inline>
    window.copy=function(){
      var t="curl -fsSL https://raw.githubusercontent.com/adndvlp/conclave/main/install.sh | bash";
      var ta=document.createElement('textarea');ta.value=t;ta.style.position='fixed';ta.style.opacity='0';document.body.appendChild(ta);ta.select();document.execCommand('copy');document.body.removeChild(ta);
      var b=document.getElementById('cb');b.textContent='Copied!';setTimeout(function(){b.textContent='Copy'},1500)};
    window.copy2=function(){
      var t="curl -fsSL https://raw.githubusercontent.com/adndvlp/conclave/main/install.sh | bash";
      var ta=document.createElement('textarea');ta.value=t;ta.style.position='fixed';ta.style.opacity='0';document.body.appendChild(ta);ta.select();document.execCommand('copy');document.body.removeChild(ta);
      var b=document.getElementById('cb2');b.textContent='Copied!';setTimeout(function(){b.textContent='Copy'},1500)};

    // Particles
    (function(){
      var c=document.getElementById('particles'),ctx=c.getContext('2d');
      var w,h,dpr,ps=[],mx=null,my=null,af;
      function resize(){
        dpr=Math.min(window.devicePixelRatio||1,2);
        w=window.innerWidth;h=window.innerHeight;
        c.width=Math.floor(w*dpr);c.height=Math.floor(h*dpr);
        c.style.width=w+'px';c.style.height=h+'px';
        ctx.setTransform(dpr,0,0,dpr,0,0);
        if(ps.length)ps.forEach(function(p){p.x=Math.min(w,Math.max(0,p.x));p.y=Math.min(h,Math.max(0,p.y))});
        else for(var i=0;i<80;i++)ps.push({x:Math.random()*w,y:Math.random()*h,vx:(Math.random()-0.5)*0.25,vy:(Math.random()-0.5)*0.25,r:Math.random()*1.8+0.6,or:0})
      }
      resize();ps.forEach(function(p){p.or=p.r});
      window.addEventListener('resize',resize);

      function upd(){
        ps.forEach(function(p){
          p.x+=p.vx;p.y+=p.vy;
          if(p.x<0||p.x>w)p.vx*=-1;
          if(p.y<0||p.y>h)p.vy*=-1;
          p.vx*=0.999;p.vy*=0.999;
          if(Math.abs(p.vx)<0.03)p.vx+=(Math.random()-0.5)*0.08;
          if(Math.abs(p.vy)<0.03)p.vy+=(Math.random()-0.5)*0.08;
          if(mx!==null){
            var dx=p.x-mx,dy=p.y-my,dist=Math.hypot(dx,dy);
            if(dist<150){var f=(150-dist)/150;var a=Math.atan2(dy,dx);p.x+=Math.cos(a)*f*0.6;p.y+=Math.sin(a)*f*0.6;p.r=p.or+f*1.4}
            else p.r=p.or
          }else p.r=p.or
        })
      }

      function draw(){
        ctx.clearRect(0,0,w,h);
        for(var i=0;i<ps.length;i++)for(var j=i+1;j<ps.length;j++){
          var dx=ps[i].x-ps[j].x,dy=ps[i].y-ps[j].y,dist=Math.hypot(dx,dy);
          if(dist<130){var op=(1-dist/130)*0.18;ctx.beginPath();ctx.moveTo(ps[i].x,ps[i].y);ctx.lineTo(ps[j].x,ps[j].y);ctx.strokeStyle='rgba(180,30,30,'+op+')';ctx.lineWidth=0.5;ctx.stroke()}
        }
        ps.forEach(function(p){
          ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
          var color='rgba(200,50,50,0.45)';
          if(mx){var dx=p.x-mx,dy=p.y-my,dist=Math.hypot(dx,dy);if(dist<150)color='rgba(220,70,70,'+(0.4+0.3*(1-dist/150))+')'}
          ctx.fillStyle=color;ctx.shadowColor='rgba(180,25,25,0.4)';ctx.shadowBlur=p.r*2;ctx.fill();ctx.shadowBlur=0
        })
      }

      function loop(){upd();draw();af=requestAnimationFrame(loop)}
      loop();

      document.addEventListener('mousemove',function(e){mx=e.clientX;my=e.clientY;var g=document.getElementById('glow');g.style.opacity='1';g.style.left=e.clientX+'px';g.style.top=e.clientY+'px'});
      document.addEventListener('mouseleave',function(){mx=null;my=null;document.getElementById('glow').style.opacity='0'});
      window.addEventListener('beforeunload',function(){if(af)cancelAnimationFrame(af)});
    })();

    // Reveal
    var obs=new IntersectionObserver(function(e){e.forEach(function(en){if(en.isIntersecting)en.target.classList.add('visible')})},{threshold:0.1});
    document.querySelectorAll('.reveal').forEach(function(el){obs.observe(el)});
  </script>
</body>
</html>
